# ==========================================================================
# TuneCamp Central - Environment Variables Configuration Template
# Copy this file to '.env' and fill in your actual credentials.
# ==========================================================================

# 1. Server Configuration
# ----------------------------------------------------
# Port on which the TuneCamp Central server will listen
TUNECAMP_PORT=1971

# Path to the SQLite database file
TUNECAMP_DB_PATH=./tunecamp-central.db

# JWT secret key for signing session tokens (use a long random string in production)
TUNECAMP_JWT_SECRET=replace-with-a-very-strong-secret-key-for-central-jwt

# 2. Stripe Connect (Express) Integration
# ----------------------------------------------------
# Your Stripe Secret Key (Sandbox/Test key starts with sk_test_, Production starts with sk_live_)
# Log in to Stripe Dashboard -> Developers -> API Keys to retrieve.
STRIPE_SECRET_KEY=sk_test_yourstripeconnectsecretkeyhere

# 3. Google Drive Storage Integration (Multi-User)
# ----------------------------------------------------
# Client ID and Client Secret from Google Cloud Console.
# Required for artists to link their personal Google Drive storage.
# Set up a Web Application OAuth Client with redirect URI:
# http://localhost:1971/api/storage/gdrive/callback (replace with your domain in production)
TUNECAMP_GDRIVE_CLIENT_ID=your-google-oauth2-client-id-here.apps.googleusercontent.com
TUNECAMP_GDRIVE_CLIENT_SECRET=GOCSPX-your-google-oauth2-client-secret-here
